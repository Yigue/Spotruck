# Spottruck Backend Environment Variables
# Copiá este archivo a .env y completá los valores

# ─── Base de datos ────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@host:5432/spottruck?schema=public"
REDIS_URL="redis://host:6379"

# ─── Servidor ────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development            # development | production
CORS_ORIGIN="http://localhost:3000"

# URLs públicas (links de emails, back_urls y webhook de MercadoPago).
# En producción usá los dominios reales, ej: https://spottruck.com
FRONTEND_URL="http://localhost:3000"
API_URL="http://localhost:4000"

# ─── Auth ────────────────────────────────────────────────────────────────────
JWT_SECRET="your-jwt-secret-min-32-chars"
JWT_REFRESH_SECRET="your-refresh-secret-min-32-chars"

# ─── MercadoPago (Checkout Pro) ──────────────────────────────────────────────
# Access token de tu aplicación: https://www.mercadopago.com.ar/developers/panel
# Usá las credenciales de PRUEBA (TEST-...) para desarrollo.
# Sin token la app funciona en modo simulado (sin cobros reales).
MERCADOPAGO_ACCESS_TOKEN=""
# Secret para validar la firma de los webhooks (sección Webhooks del panel).
# Vacío = no se valida la firma (solo recomendable en desarrollo).
MERCADOPAGO_WEBHOOK_SECRET=""

# ─── Emails (Resend) ─────────────────────────────────────────────────────────
# API key de https://resend.com — sin key los emails se loguean por consola.
RESEND_API_KEY=""
# Remitente verificado en Resend. Para pruebas sirve onboarding@resend.dev
EMAIL_FROM="Spottruck <onboarding@resend.dev>"
