// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// ENUMS
// ============================================

enum UserRole {
  COMPANY
  DRIVER
  ADMIN
}

enum CargoType {
  BULK
  PALLETS
  GENERAL
  REFRIGERATED
}

enum TripStatus {
  DRAFT
  OPEN
  AUCTION
  ASSIGNED
  IN_PROGRESS
  DELIVERED
  SETTLED
  CANCELLED
}

enum AuctionType {
  OPEN
  DUTCH
  SEALED
}

enum AuctionStatus {
  PENDING
  OPEN
  CLOSED
  SETTLED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  HELD
  RELEASED
  REFUNDED
  DISPUTED
}

enum TruckType {
  JAULA
  SEMI
  TOLVA
  BATEA
  FURGON
  REFRIGERADO
  PLAYO
  OTRO
}

enum BidStatus {
  PENDING
  ACCEPTED
  REJECTED
  WITHDRAWN
}

enum DocumentsStatus {
  NONE
  PENDING
  APPROVED
  REJECTED
}

// ============================================
// MODELS
// ============================================

model User {
  id              String   @id @default(uuid())
  email           String   @unique
  passwordHash    String   @map("password_hash")
  role            UserRole @default(COMPANY)

  // Company fields
  companyName     String?  @map("company_name")
  companyCuit    String?  @map("company_cuit")
  phone           String?

  // Driver fields
  driverLicense  String?  @map("driver_license")
  vehiclePlate   String?  @map("vehicle_plate")
  vehicleType    String?  @map("vehicle_type")
  vehicleCapacity Float?  @map("vehicle_capacity_kg")
  preferredZone  String?  @map("preferred_zone")

  // Profile
  emailVerified  Boolean  @default(false) @map("email_verified")
  emailVerifyToken String? @unique @map("email_verify_token")
  passwordResetToken String? @unique @map("password_reset_token")
  passwordResetExpires DateTime? @map("password_reset_expires")
  // Revisión de documentación del transportista (licencia, cédula, seguro)
  documentsStatus DocumentsStatus @default(NONE) @map("documents_status")
  driverLicenseUrl String? @map("driver_license_url")
  address        String?
  website        String?
  sector         String?

  // Stats
  ratingAvg      Float    @default(0) @map("rating_avg")
  ratingCount    Int      @default(0) @map("rating_count")
  tripsCompleted Int      @default(0) @map("trips_completed")
  trustScore     Float    @default(0.5) @map("trust_score")

  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  trips          Trip[]
  bids           Bid[]
  ratingsGiven   Rating[] @relation("ratings_given")
  ratingsReceived Rating[] @relation("ratings_received")
  payments       Payment[]
  trucks         Truck[]
  notifications  Notification[]

  @@map("users")
}

model Truck {
  id              String     @id @default(uuid())
  ownerId         String     @map("owner_id")
  owner           User       @relation(fields: [ownerId], references: [id])

  plate           String     @unique
  type            TruckType
  capacityKg      Float      @map("capacity_kg")
  preferredCargo  CargoType? @map("preferred_cargo")

  // Documentación opcional (transporte de alimentos / seguro)
  senasaNumber    String?    @map("senasa_number")
  insurance       Json?      // { aseguradora, tipo, monto, vencimiento }
  documentsUrl    String[]   @map("documents_url")

  active          Boolean    @default(true)

  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  bids            Bid[]

  @@map("trucks")
  @@index([ownerId])
}

model Trip {
  id              String    @id @default(uuid())
  userId          String    @map("user_id")
  user            User      @relation(fields: [userId], references: [id])

  // Origin
  originAddress   String    @map("origin_address")
  originLat       Float     @map("origin_lat")
  originLng       Float     @map("origin_lng")
  originProvince  String?   @map("origin_province")
  originCity      String?   @map("origin_city")

  // Destination
  destAddress     String    @map("dest_address")
  destLat         Float     @map("dest_lat")
  destLng         Float     @map("dest_lng")
  destProvince    String?   @map("dest_province")
  destCity        String?   @map("dest_city")

  // Route (calculada al crear la publicación)
  distanceKm      Float?    @map("distance_km")
  durationMin     Int?      @map("duration_min")

  // Cargo
  cargoType       CargoType @map("cargo_type")
  cargoDesc       String?   @map("cargo_desc")
  weightKg        Float?    @map("weight_kg")
  volumeDesc      String?   @map("volume_desc")

  // Scheduling
  scheduledDate   DateTime  @map("scheduled_date")
  endDate         DateTime? @map("end_date")

  // Pricing
  basePrice       Decimal   @map("base_price") @db.Decimal(12, 2)

  // Status
  status          TripStatus @default(DRAFT)

  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  auction         Auction?
  payments        Payment[]
  ratings         Rating[]
  trackingLogs    TrackingLog[]

  @@map("trips")
}

model Auction {
  id              String        @id @default(uuid())
  tripId          String        @unique @map("trip_id")
  trip            Trip          @relation(fields: [tripId], references: [id])

  type            AuctionType   @default(OPEN)
  startTime       DateTime      @map("start_time")
  endTime         DateTime      @map("end_time")
  status          AuctionStatus @default(PENDING)

  currentPrice    Decimal       @map("current_price") @db.Decimal(12, 2)
  reservePrice    Decimal?      @map("reserve_price") @db.Decimal(12, 2)

  extensionCount  Int           @default(0) @map("extension_count")

  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  bids            Bid[]

  @@map("auctions")
}

model Bid {
  id              String    @id @default(uuid())
  auctionId       String    @map("auction_id")
  auction         Auction   @relation(fields: [auctionId], references: [id])
  userId          String    @map("user_id")
  user            User      @relation(fields: [userId], references: [id])

  amount          Decimal   @db.Decimal(12, 2)
  note            String?   // "Aclaración" del transportista al postularse
  status          BidStatus @default(PENDING)

  truckId         String?   @map("truck_id")
  truck           Truck?    @relation(fields: [truckId], references: [id])

  createdAt       DateTime  @default(now()) @map("created_at")

  @@map("bids")
  @@index([auctionId, createdAt(sort: Desc)])
}

model Notification {
  id              String    @id @default(uuid())
  userId          String    @map("user_id")
  user            User      @relation(fields: [userId], references: [id])

  type            String    // NEW_BID, BID_ACCEPTED, BID_REJECTED, TRIP_STATE, AUCTION_CLOSED
  title           String
  body            String?
  payload         Json?     // ids de referencia (tripId, auctionId, bidId)

  readAt          DateTime? @map("read_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  @@map("notifications")
  @@index([userId, createdAt(sort: Desc)])
}

model Payment {
  id                String        @id @default(uuid())
  tripId            String        @map("trip_id")
  trip              Trip          @relation(fields: [tripId], references: [id])
  userId            String        @map("user_id")
  user              User          @relation(fields: [userId], references: [id])

  amount            Decimal       @db.Decimal(12, 2)
  platformFee       Decimal       @map("platform_fee") @db.Decimal(12, 2)
  netAmount         Decimal       @map("net_amount") @db.Decimal(12, 2)
  status            PaymentStatus @default(PENDING)

  mercadopagoId    String?       @map("mercadopago_id")
  mercadopagoStatus String?      @map("mercadopago_status")
  paymentUrl       String?       @map("payment_url")
  holdExpiresAt    DateTime?     @map("hold_expires_at")

  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")

  @@map("payments")
}

model Rating {
  id              String    @id @default(uuid())
  tripId          String    @map("trip_id")
  trip            Trip      @relation(fields: [tripId], references: [id])
  fromUserId      String    @map("from_user_id")
  fromUser        User      @relation("ratings_given", fields: [fromUserId], references: [id])
  toUserId        String    @map("to_user_id")
  toUser          User      @relation("ratings_received", fields: [toUserId], references: [id])

  score           Float     // 1-5
  punctuality     Float?    // 1-5
  communication   Float?    // 1-5
  cargoCondition  Float?    // 1-5
  comment         String?

  createdAt       DateTime  @default(now()) @map("created_at")

  @@unique([tripId, fromUserId])
  @@map("ratings")
}

model TrackingLog {
  id              String    @id @default(uuid())
  tripId          String    @map("trip_id")
  trip            Trip      @relation(fields: [tripId], references: [id])

  lat             Float
  lng             Float
  speed           Float?    // km/h
  heading         Float?    // degrees

  recordedAt      DateTime  @default(now()) @map("recorded_at")

  @@map("tracking_logs")
  @@index([tripId, recordedAt])
}
