# Spottruck Environment Configuration
# Generated by Ansible - DO NOT COMMIT TO VERSION CONTROL

# Application
NODE_ENV={{ node_env | default('production') }}
PORT={{ app_port | default('3001') }}
APP_URL={{ app_url | default('https://spottruck.com') }}

# Database
DATABASE_URL={{ database_url }}
RDS_HOST={{ rds_host | default('') }}
RDS_PORT={{ rds_port | default('5432') }}
RDS_DB_NAME={{ rds_db_name | default('spottruck') }}

# Authentication
JWT_SECRET={{ jwt_secret }}
JWT_EXPIRES_IN={{ jwt_expires_in | default('7d') }}

# Redis
REDIS_URL={{ redis_url | default('redis://localhost:6379') }}

# MercadoPago
MERCADOPAGO_ACCESS_TOKEN={{ mercadopago_access_token }}
MERCADOPAGO_WEBHOOK_SECRET={{ mercadopago_webhook_secret | default('') }}

# CORS
CORS_ORIGIN={{ cors_origin | default(app_url) }}

# Email (optional)
SMTP_HOST={{ smtp_host | default('') }}
SMTP_PORT={{ smtp_port | default('587') }}
SMTP_USER={{ smtp_user | default('') }}
SMTP_PASS={{ smtp_pass | default('') }}

# Frontend
VITE_API_URL={{ vite_api_url | default('http://localhost:3001') }}
VITE_WS_URL={{ vite_ws_url | default('ws://localhost:3001') }}
